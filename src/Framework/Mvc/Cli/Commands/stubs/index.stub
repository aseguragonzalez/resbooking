<?php

declare(strict_types=1);

require_once __DIR__ . '/{{autoloadPath}}';

use DI\Container;
use Framework\Mvc\Container\PhpDiServiceRegistry;
use {{namespace}}\{{name}}App;
use {{namespace}}\{{name}}Bootstrap;

$container = new Container();
{{name}}Bootstrap::register($container, __DIR__);
$app = new {{name}}App(container: new PhpDiServiceRegistry($container), basePath: __DIR__);
$app->run();
